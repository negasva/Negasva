# ─────────────────────────────────────────────────────────────────────────
# Copy this file to `.env.local` and fill in real values.
# NEVER commit `.env.local` (it is git-ignored).
# Variables prefixed with NEXT_PUBLIC_ are exposed to the browser; everything
# else is server-only and must stay secret.
# ─────────────────────────────────────────────────────────────────────────

# Supabase (public — safe to expose)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase service role key (SERVER-ONLY — bypasses RLS, NEVER expose).
# Used by webhooks and the /api/keepalive endpoint.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Keep-alive endpoint (optional but recommended).
# If set, /api/keepalive requires this token via `?token=` or the
# `x-keepalive-token` header. Leave empty to keep the endpoint open
# (still rate-limited and read-only). Use a long random string.
KEEPALIVE_SECRET=

# Vercel Cron secret (optional). Set this if you use KEEPALIVE_SECRET, so the
# daily Vercel Cron (defined in vercel.json) can authenticate via the
# `Authorization: Bearer <CRON_SECRET>` header that Vercel sends automatically.
# If KEEPALIVE_SECRET is empty, the cron works without this.
CRON_SECRET=

# Stripe
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Mercado Pago (pagos en Colombia, COP). Token de producción APP_USR-… o de
# prueba TEST-…; el webhook es /api/webhooks/mercadopago.
MERCADOPAGO_ACCESS_TOKEN=

# PayPal vía Stripe (hay que activarlo antes en el dashboard de Stripe).
# Ponlo en "true" solo cuando esté activado; si no, rompería el checkout.
STRIPE_PAYPAL_ENABLED=

# Wompi (legacy — solo para webhooks de pedidos antiguos)
WOMPI_PUBLIC_KEY=
WOMPI_INTEGRITY_SECRET=
WOMPI_EVENTS_SECRET=

# Admin panel auth (single shared password — no Supabase Auth users).
# ADMIN_PASSWORD is required for the admin panel to work. ADMIN_SESSION_SECRET
# is the HMAC key for the signed session cookie; if empty, ADMIN_PASSWORD is
# used as the key (rotating the password then invalidates live sessions).
ADMIN_PASSWORD=
ADMIN_SESSION_SECRET=

# New-order notification email via Resend REST API (optional). All three must
# be set to send. RESEND_FROM must be a verified sender/domain in Resend.
RESEND_API_KEY=
RESEND_FROM=
ADMIN_NOTIFY_EMAIL=

# Site / misc
NEXT_PUBLIC_SITE_URL=https://negasva.shop
NEXT_PUBLIC_GA_ID=
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=
# Server-only reCAPTCHA v3 secret. Si se define, el backend verifica los tokens
# de los formularios (newsletter estricto, checkout best-effort). Si se deja
# vacío, la verificación se omite (no rompe dev).
RECAPTCHA_SECRET_KEY=
# Comma-separated list of extra allowed origins for CSRF checks (optional)
ALLOWED_ORIGINS=

# Print-on-demand (Printful) — OPTIONAL. The store already lets customers add
# physical products (mug, t-shirt, pillow, canvas, tote, phone case) to an order
# and charges for them; fulfillment is done by uploading the finished
# illustration to Printful as the print file (https://developers.printful.com).
# Token privado: Printful → Settings → Stores → Add API.
# Per-product retail prices are managed in the admin `prices` table under keys
# like `pod_mug`, `pod_tshirt`, … (fallbacks live in lib/pricing/products.ts).
PRINTFUL_API_TOKEN=
# Mapeo producto → variant_id de Printful para cotizar envío. Cada valor puede
# ser un id directo o un objeto por variante ("talla/color") con "default":
# {"mug":1320,"tshirt":{"S/white":4011,"M/black":4013,"default":4011}}
PRINTFUL_VARIANT_MAP=

# Upstash Redis (optional but recommended in production). When BOTH are set,
# rate limiting and CSRF tokens use a global Redis-backed store shared across
# all serverless instances. If unset, both fall back to per-instance memory.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
